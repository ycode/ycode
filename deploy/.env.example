###############################################################################
# Ycode Self-Hosted — Docker Environment Configuration
# Copy this file to .env and fill in the values
# Run: bash scripts/generate-secrets.sh to auto-generate secrets
###############################################################################

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# ─── JWT / Crypto (generated by generate-secrets.sh) ────────────────────────
JWT_SECRET=CHANGE_ME
JWT_EXPIRY=3600
SECRET_KEY_BASE=CHANGE_ME
VAULT_ENC_KEY=CHANGE_ME
PG_META_CRYPTO_KEY=CHANGE_ME
ANON_KEY=CHANGE_ME
SERVICE_ROLE_KEY=CHANGE_ME

# ─── Supabase Dashboard ─────────────────────────────────────────────────────
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=CHANGE_ME

# ─── URLs (MUST UPDATE with your domain) ─────────────────────────────────────
# Your ycode app URL (e.g. https://ycode.example.com)
SITE_URL=https://ycode.example.com
# Your Supabase API public URL (Kong gateway, e.g. https://supa.example.com)
API_EXTERNAL_URL=https://supa.example.com
SUPABASE_PUBLIC_URL=https://supa.example.com
# Hostname for Next.js image optimization (without protocol)
SELF_HOSTED_SUPABASE_HOSTNAME=supa.example.com

# ─── Kong API Gateway ───────────────────────────────────────────────────────
# Port exposed on Unraid LAN for direct access to Studio + API
KONG_HTTP_PORT=3080

# ─── Supavisor Connection Pooler ─────────────────────────────────────────────
POOLER_TENANT_ID=CHANGE_ME
POOLER_DEFAULT_POOL_SIZE=20
POOLER_MAX_CLIENT_CONN=100

# ─── Auth (GoTrue) ──────────────────────────────────────────────────────────
ENABLE_EMAIL_AUTOCONFIRM=true
ENABLE_EMAIL_SIGNUP=true
DISABLE_SIGNUP=false
ADDITIONAL_REDIRECT_URLS=
ENABLE_PHONE_SIGNUP=false
ENABLE_ANONYMOUS_USERS=false
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify

# ─── SMTP (optional — leave empty to disable email sending) ──────────────────
SMTP_ADMIN_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─── PostgREST ──────────────────────────────────────────────────────────────
PGRST_DB_SCHEMAS=public,storage,graphql_public

# ─── Studio ──────────────────────────────────────────────────────────────────
STUDIO_DEFAULT_ORGANIZATION=Ycode
STUDIO_DEFAULT_PROJECT=ycode

# ─── Analytics / Logflare ───────────────────────────────────────────────────
LOGFLARE_PRIVATE_ACCESS_TOKEN=CHANGE_ME
LOGFLARE_PUBLIC_ACCESS_TOKEN=CHANGE_ME

# ─── Functions ───────────────────────────────────────────────────────────────
FUNCTIONS_VERIFY_JWT=false

# ─── Image Proxy ─────────────────────────────────────────────────────────────
IMGPROXY_ENABLE_WEBP_DETECTION=true

# ─── Docker Socket (Unraid default) ─────────────────────────────────────────
DOCKER_SOCKET_LOCATION=/var/run/docker.sock

# ─── Ycode App ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_TEMPLATE_API_URL=
TEMPLATE_API_URL=
TEMPLATE_UPLOAD_API_KEY=
PAGE_AUTH_SECRET=CHANGE_ME
GOOGLE_FONTS_API_KEY=

# ─── Cloudflare Tunnel ──────────────────────────────────────────────────────
# Get this from Cloudflare Zero Trust > Networks > Tunnels > your tunnel
CLOUDFLARE_TUNNEL_TOKEN=CHANGE_ME
